{
  "info": {
    "name": "Custom Web Platform — Backend Dev 1",
    "description": "All Backend Dev 1 API endpoints: Auth, Sites, Navigation, Members",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "siteId",
      "value": ""
    },
    {
      "key": "memberId",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Password123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Password123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/profile",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "profile"]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"avatarUrl\": \"https://example.com/avatar.png\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/profile",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Sites",
      "item": [
        {
          "name": "Create Site",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data._id) {",
                  "  pm.collectionVariables.set('siteId', res.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Hotel Website\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/sites",
              "host": ["{{baseUrl}}"],
              "path": ["sites"]
            }
          }
        },
        {
          "name": "Get All Sites",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sites",
              "host": ["{{baseUrl}}"],
              "path": ["sites"]
            }
          }
        },
        {
          "name": "Get Site by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sites/{{siteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["sites", "{{siteId}}"]
            }
          }
        },
        {
          "name": "Update Site",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Updated Hotel Website\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/sites/{{siteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["sites", "{{siteId}}"]
            }
          }
        },
        {
          "name": "Delete Site",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sites/{{siteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["sites", "{{siteId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Navigation",
      "item": [
        {
          "name": "Get Navigation",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sites/{{siteId}}/navigation",
              "host": ["{{baseUrl}}"],
              "path": ["sites", "{{siteId}}", "navigation"]
            }
          }
        },
        {
          "name": "Update Navigation",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"id\": \"nav_1\",\n      \"label\": \"Home\",\n      \"url\": \"/home\",\n      \"order\": 1,\n      \"isVisible\": true,\n      \"children\": []\n    },\n    {\n      \"id\": \"nav_2\",\n      \"label\": \"About\",\n      \"url\": \"/about\",\n      \"order\": 2,\n      \"isVisible\": true,\n      \"children\": []\n    },\n    {\n      \"id\": \"nav_3\",\n      \"label\": \"Services\",\n      \"url\": \"/services\",\n      \"order\": 3,\n      \"isVisible\": true,\n      \"children\": [\n        {\n          \"id\": \"nav_3_1\",\n          \"label\": \"Web Design\",\n          \"url\": \"/services/web-design\",\n          \"order\": 1,\n          \"isVisible\": true,\n          \"children\": []\n        }\n      ]\n    },\n    {\n      \"id\": \"nav_4\",\n      \"label\": \"Contact\",\n      \"url\": \"/contact\",\n      \"order\": 4,\n      \"isVisible\": true,\n      \"children\": []\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/sites/{{siteId}}/navigation",
              "host": ["{{baseUrl}}"],
              "path": ["sites", "{{siteId}}", "navigation"]
            }
          }
        }
      ]
    },
    {
      "name": "Members",
      "item": [
        {
          "name": "List Members",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sites/{{siteId}}/members",
              "host": ["{{baseUrl}}"],
              "path": ["sites", "{{siteId}}", "members"]
            }
          }
        },
        {
          "name": "Invite Member",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data._id) {",
                  "  pm.collectionVariables.set('memberId', res.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teammate@example.com\",\n  \"role\": \"editor\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/sites/{{siteId}}/members/invite",
              "host": ["{{baseUrl}}"],
              "path": ["sites", "{{siteId}}", "members", "invite"]
            }
          }
        },
        {
          "name": "Update Member Role",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"viewer\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/sites/{{siteId}}/members/{{memberId}}",
              "host": ["{{baseUrl}}"],
              "path": ["sites", "{{siteId}}", "members", "{{memberId}}"]
            }
          }
        },
        {
          "name": "Remove Member",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sites/{{siteId}}/members/{{memberId}}",
              "host": ["{{baseUrl}}"],
              "path": ["sites", "{{siteId}}", "members", "{{memberId}}"]
            }
          }
        }
      ]
    }
  ]
}
