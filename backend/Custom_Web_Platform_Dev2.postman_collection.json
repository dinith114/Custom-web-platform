{
  "info": {
    "name": "Custom Web Platform — Backend Dev 2",
    "description": "Backend Dev 2 API endpoints: Pages, Media, Public delivery, Templates. Requires a valid Bearer token and a siteId for authenticated routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "siteId",
      "value": ""
    },
    {
      "key": "siteSlug",
      "value": ""
    },
    {
      "key": "pageId",
      "value": ""
    },
    {
      "key": "pageSlug",
      "value": ""
    },
    {
      "key": "mediaId",
      "value": ""
    },
    {
      "key": "templateId",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Pages",
      "item": [
        {
          "name": "List Pages",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sites/{{siteId}}/pages",
              "host": ["{{baseUrl}}"],
              "path": ["sites", "{{siteId}}", "pages"]
            }
          }
        },
        {
          "name": "Create Page",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data._id) {",
                  "  pm.collectionVariables.set('pageId', res.data._id);",
                  "  if (res.data.slug) {",
                  "    pm.collectionVariables.set('pageSlug', res.data.slug);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Home\",\n  \"slug\": \"home\",\n  \"isHomePage\": true,\n  \"draftContent\": {\n    \"sections\": [\n      {\n        \"id\": \"sec_1\",\n        \"type\": \"hero\",\n        \"order\": 1,\n        \"components\": [\n          {\n            \"type\": \"heading\",\n            \"text\": \"Welcome\",\n            \"style\": { \"fontSize\": \"42px\", \"color\": \"#111827\" }\n          }\n        ]\n      }\n    ]\n  },\n  \"seoTitle\": \"Home\",\n  \"seoDescription\": \"Homepage description\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/sites/{{siteId}}/pages",
              "host": ["{{baseUrl}}"],
              "path": ["sites", "{{siteId}}", "pages"]
            }
          }
        },
        {
          "name": "Get Page by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sites/{{siteId}}/pages/{{pageId}}",
              "host": ["{{baseUrl}}"],
              "path": ["sites", "{{siteId}}", "pages", "{{pageId}}"]
            }
          }
        },
        {
          "name": "Update Page",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Home Updated\",\n  \"draftContent\": {\n    \"sections\": [\n      {\n        \"id\": \"sec_1\",\n        \"type\": \"hero\",\n        \"order\": 1,\n        \"components\": [\n          {\n            \"type\": \"heading\",\n            \"text\": \"Updated Welcome\"\n          }\n        ]\n      }\n    ]\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/sites/{{siteId}}/pages/{{pageId}}",
              "host": ["{{baseUrl}}"],
              "path": ["sites", "{{siteId}}", "pages", "{{pageId}}"]
            }
          }
        },
        {
          "name": "Publish Page",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sites/{{siteId}}/pages/{{pageId}}/publish",
              "host": ["{{baseUrl}}"],
              "path": ["sites", "{{siteId}}", "pages", "{{pageId}}", "publish"]
            }
          }
        },
        {
          "name": "Delete Page",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sites/{{siteId}}/pages/{{pageId}}",
              "host": ["{{baseUrl}}"],
              "path": ["sites", "{{siteId}}", "pages", "{{pageId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Media",
      "item": [
        {
          "name": "List Media",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sites/{{siteId}}/media",
              "host": ["{{baseUrl}}"],
              "path": ["sites", "{{siteId}}", "media"]
            }
          }
        },
        {
          "name": "Upload Media",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/sites/{{siteId}}/media/upload",
              "host": ["{{baseUrl}}"],
              "path": ["sites", "{{siteId}}", "media", "upload"]
            }
          }
        },
        {
          "name": "Delete Media",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sites/{{siteId}}/media/{{mediaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["sites", "{{siteId}}", "media", "{{mediaId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Public",
      "item": [
        {
          "name": "Get Published Site",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/public/sites/{{siteSlug}}",
              "host": ["{{baseUrl}}"],
              "path": ["public", "sites", "{{siteSlug}}"]
            }
          }
        },
        {
          "name": "Get Published Page",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/public/sites/{{siteSlug}}/pages/{{pageSlug}}",
              "host": ["{{baseUrl}}"],
              "path": [
                "public",
                "sites",
                "{{siteSlug}}",
                "pages",
                "{{pageSlug}}"
              ]
            }
          }
        },
        {
          "name": "Get Published Navigation",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/public/sites/{{siteSlug}}/navigation",
              "host": ["{{baseUrl}}"],
              "path": ["public", "sites", "{{siteSlug}}", "navigation"]
            }
          }
        }
      ]
    },
    {
      "name": "Templates",
      "item": [
        {
          "name": "List Templates",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/templates",
              "host": ["{{baseUrl}}"],
              "path": ["templates"]
            }
          }
        },
        {
          "name": "Get Template by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/templates/{{templateId}}",
              "host": ["{{baseUrl}}"],
              "path": ["templates", "{{templateId}}"]
            }
          }
        }
      ]
    }
  ]
}
